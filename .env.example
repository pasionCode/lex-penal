# =============================================================================
# LEX_PENAL — Variables de entorno
# =============================================================================
# Copiar este archivo como .env y completar los valores reales.
# NUNCA subir .env al repositorio.
# =============================================================================

# -----------------------------------------------------------------------------
# Servidor
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3001

# -----------------------------------------------------------------------------
# Base de datos (PostgreSQL)
# -----------------------------------------------------------------------------
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://lexpenal:lexpenal_dev@localhost:5432/lexpenal_dev?schema=public"

# -----------------------------------------------------------------------------
# Autenticación (JWT)
# -----------------------------------------------------------------------------
# Generar con: openssl rand -base64 64
JWT_SECRET="CAMBIAR_EN_PRODUCCION_generar_con_openssl_rand_base64_64"
JWT_EXPIRES_IN="24h"

# -----------------------------------------------------------------------------
# Módulo IA (Anthropic)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY="sk-ant-api03-..."
ANTHROPIC_MODEL="claude-sonnet-4-20250514"
ANTHROPIC_MAX_TOKENS=4096

# -----------------------------------------------------------------------------
# Cookies de sesión
# -----------------------------------------------------------------------------
COOKIE_SECRET="CAMBIAR_EN_PRODUCCION_generar_secreto_largo"
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ORIGIN="http://localhost:3000"

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
LOG_LEVEL=debug
